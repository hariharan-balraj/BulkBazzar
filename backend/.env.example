# Copy this to .env and fill in values

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database path
DB_PATH=app.db

# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://bulkbazaar.in,https://www.bulkbazaar.in

# Razorpay (get from razorpay.com dashboard)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Razorpay Plan IDs (create plans in Razorpay dashboard first)
RAZORPAY_PLAN_VERIFIED_SELLER=
RAZORPAY_PLAN_UNLIMITED_BUYER=
RAZORPAY_PLAN_CONTACT_PACK=
